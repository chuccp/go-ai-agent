# .vscode/
/cmd/server/view/node_modules
/.idea
*.yml
/data
go-ai-agent
/build
/cmd/server/view/wailsjs
/cmd/server/view/package.json.md5
/cmd/server/view/tsconfig.tsbuildinfo
/cmd/server/view/dist
/cmd/server/view/build
PLAN.md
/server
/go-ai-agent-server
/.claude
